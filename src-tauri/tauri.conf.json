{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lios",
  "version": "0.1.0",
  "identifier": "dev.lios.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lios",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
